{
  "settings": {
    "size": { "x": 1920, "y": 1080 },
    "background": "#000000"
  },
  "timeline": [
    {
      "id": "bg-video",
      "type": "video",
      "src": "https://revideo-example-assets.s3.amazonaws.com/stars.mp4",
      "startTime": 0,
      "duration": 10,
      "position": { "x": 0, "y": 0 },
      "size": { "width": "100%", "height": "100%" },
      "opacity": 1,
      "loop": false,
      "play": true
    },
    {
      "id": "second-video",
      "type": "video",
      "src": "https://revideo-example-assets.s3.amazonaws.com/stars.mp4",
      "startTime": 5,
      "duration": 5,
      "position": { "x": 400, "y": 200 },
      "size": { "width": 400, "height": 300 },
      "opacity": 0.8,
      "loop": false,
      "play": true
    },
    {
      "id": "bg-music",
      "type": "audio",
      "src": "https://revideo-example-assets.s3.amazonaws.com/chill-beat.mp3",
      "startTime": 0,
      "audioStartTime": 17.0,
      "play": true
    },
    {
      "id": "logo-1",
      "type": "image",
      "src": "https://revideo-example-assets.s3.amazonaws.com/revideo-logo-white.png",
      "startTime": 1,
      "position": { "x": 0, "y": 0 },
      "size": { "width": "1%" },
      "opacity": 1,
      "animations": [
        { "type": "scale",    "to": 40,  "duration": 2 },
        { "type": "rotation", "to": 360, "duration": 2 },
        { "type": "scale",    "to": 60,  "duration": 1 }
      ]
    },
    {
      "id": "logo-2",
      "type": "image",
      "src": "https://revideo-example-assets.s3.amazonaws.com/revideo-logo-white.png",
      "startTime": 4,
      "position": { "x": -600, "y": -300 },
      "size": { "width": 100 },
      "opacity": 0,
      "animations": [
        { "type": "opacity", "to": 1,   "duration": 1 },
        { "type": "scale",   "to": 1.5, "duration": 2 }
      ]
    },
    {
      "id": "title-text",
      "type": "text",
      "text": "Hello World",
      "startTime": 0,
      "position": { "x": 0, "y": -200 },
      "fontSize": 80,
      "fontFamily": "Arial",
      "fill": "#ffffff",
      "opacity": 0,
      "animations": [
        { "type": "opacity",  "to": 1,                    "duration": 1 },
        { "type": "position", "to": { "x": 0, "y": -150 }, "duration": 2 }
      ]
    },
    {
      "id": "subtitle-text",
      "type": "text",
      "text": "Made with Revideo",
      "startTime": 2,
      "position": { "x": 0, "y": 0 },
      "fontSize": 40,
      "fontFamily": "Arial",
      "fill": "#aaaaaa",
      "opacity": 0,
      "animations": [
        { "type": "opacity", "to": 1, "duration": 1.5 }
      ]
    },
    {
      "id": "highlight-text",
      "type": "text",
      "text": "Dynamic JSON Config",
      "startTime": 5,
      "position": { "x": 0, "y": 200 },
      "fontSize": 60,
      "fontFamily": "Arial",
      "fill": "#ff6600",
      "opacity": 0,
      "animations": [
        { "type": "opacity", "to": 1,   "duration": 1 },
        { "type": "scale",   "to": 1.2, "duration": 1 },
        { "type": "scale",   "to": 1,   "duration": 1 }
      ]
    }
  ]
}